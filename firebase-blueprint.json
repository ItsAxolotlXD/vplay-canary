{
  "entities": {
    "User": {
      "title": "User",
      "description": "A user of the application",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "The user's unique ID" },
        "email": { "type": "string", "format": "email", "description": "The user's email address" },
        "displayName": { "type": "string", "description": "The user's display name" },
        "photoURL": { "type": "string", "description": "The user's profile photo URL" },
        "watchedChannels": { "type": "array", "items": { "type": "string" }, "description": "List of channels the user has watched" },
        "role": { "type": "string", "enum": ["admin", "user"], "description": "The user's role" },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the user was created" }
      },
      "required": ["uid", "email", "role", "createdAt"]
    },
    "Video": {
      "title": "Video",
      "description": "A video uploaded by a user",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "The video's unique ID" },
        "title": { "type": "string", "description": "The title of the video" },
        "description": { "type": "string", "description": "A description of the video" },
        "url": { "type": "string", "description": "The URL of the video file" },
        "thumbnail": { "type": "string", "description": "The URL of the thumbnail image" },
        "userId": { "type": "string", "description": "The ID of the user who uploaded the video" },
        "userName": { "type": "string", "description": "The name of the user who uploaded the video" },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the video was uploaded" }
      },
      "required": ["id", "title", "url", "userId", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "Stores user profiles and roles"
    },
    "/videos/{videoId}": {
      "schema": { "$ref": "#/entities/Video" },
      "description": "Stores uploaded videos metadata"
    },
    "/posts/{postId}": {
      "schema": {
        "title": "Post",
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "content": { "type": "string" },
          "mediaUrl": { "type": "string" },
          "mediaType": { "type": "string", "enum": ["image", "video", "none"] },
          "poll": {
            "type": "object",
            "properties": {
              "question": { "type": "string" },
              "options": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "text": { "type": "string" },
                    "votes": { "type": "number" }
                  }
                }
              }
            }
          },
          "userId": { "type": "string" },
          "userName": { "type": "string" },
          "createdAt": { "type": "string", "format": "date-time" }
        }
      },
      "description": "Community posts with media and polls"
    }
  }
}
